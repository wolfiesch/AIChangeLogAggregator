# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# GitHub API (for GitHub scraper)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Scraper API Key (for triggering scrapes)
SCRAPER_API_KEY=your-secret-api-key

# Vercel ISR Revalidation (optional)
VERCEL_REVALIDATE_URL=https://your-app.vercel.app/api/revalidate

# Site URL (for RSS feed)
NEXT_PUBLIC_SITE_URL=https://aichangelog.dev
